<%# app/components/common/order_edit_component.html.erb %>
<div data-controller="common--order-edit-component" 
     data-common--order-edit-component-units-value="<%= Biz::Unit.all.map { |u| { service_type: u.service_type, category_id: u.category_id, price: u.price.to_f, unit_id: u.id } }.to_json %>"
     class="w-full max-w-4xl mx-auto space-y-4 pb-12 text-slate-700">

  <%# 顶部：标题与实时金额预览 %>
  <div class="flex items-center justify-between border-b border-slate-100 pb-4">
    <div class="flex items-center gap-3">
      <div class="flex items-center justify-center w-9 h-9 bg-white border border-slate-200 rounded-xl <%= @color%> shadow-sm">
        <%= heroicon @icon, variant: :outline, options: { class: "h-5 w-5" } %>
      </div>
      <div>
        <h2 class="text-lg font-black text-slate-900 tracking-tight"><%= @title%></h2>
        <p class="text-[10px] text-slate-400 font-mono tracking-tighter">单号: <%= @order.order_no %></p>
      </div>
    </div>
    
    <%# 金额预览卡片 %>
    <div class="px-5 py-2 bg-[#0066b3] rounded-xl shadow-lg shadow-blue-900/20">
      <div class="text-[9px] font-bold text-blue-100 tracking-widest text-right opacity-80"><%= @amount_title%></div>
      <div class="text-xl font-mono font-black text-white leading-none">
        <span class="text-xs mr-0.5 italic">¥</span>
        <span data-common--order-edit-component-target="amountDisplay"><%= @amount %></span>
      </div>
    </div>
  </div>

  <%# --- 核心新增：退回原因显示区域 --- %>
  <% if @order.status == "rejected" && @order.reject_reason.present? %>
    <div class="bg-amber-50 border-2 border-amber-200 rounded-2xl p-5 flex gap-4 items-start animate-in fade-in slide-in-from-top-4 duration-500">
      <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-amber-500 shrink-0 shadow-sm">
        <%= heroicon "exclamation-triangle", variant: :solid, options: { class: "h-5 w-5" } %>
      </div>
      <div class="space-y-1">
        <h4 class="text-[10px] font-black text-amber-800 tracking-widest">审核退回说明</h4>
        <p class="text-sm font-bold text-amber-900 leading-relaxed"><%= @order.reject_reason %></p>
        <div class="flex items-center gap-2 mt-2">
          <span class="text-[9px] px-1.5 py-0.5 bg-amber-200/50 text-amber-800 rounded font-bold">
            操作人: <%= @order.staff&.name %>
          </span>
          <span class="text-[9px] text-amber-600/60 font-mono font-bold">
            <%= @order.updated_at.strftime("%Y-%m-%d %H:%M") %>
          </span>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with model: @order, url: @url, method: @method, data: { turbo: false }, class: "space-y-4" do |f| %>
    <%= f.hidden_field :order_no %>
    <%= f.hidden_field :unit_id, data: { "common--order-edit-component-target" => "unitIdInput" } %>

    <%# 第一区：稿件区 %>
    <div class="bg-white border-2 border-dashed border-slate-200 rounded-2xl p-6 transition-all hover:border-[#0066b3]/30 group cursor-pointer relative"
         data-common--order-edit-component-target="uploadContainer">
      <%= f.fields_for :draft do |df| %>
        <%= df.hidden_field :user_id %>
        <label for="order_draft_file" class="flex flex-col items-center justify-center space-y-2 cursor-pointer w-full h-full">
          <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center group-hover:bg-blue-50 transition-colors text-slate-400 group-hover:text-[#0066b3]">
            <%= heroicon "document-arrow-up", variant: :outline, options: { class: "h-5 w-5" } %>
          </div>
          <div class="text-center">
            <span class="text-xs font-black <%= @display_cls %> block transition-all" data-common--order-edit-component-target="fileNameDisplay">
              <%= @display %>
            </span>
            <%# 核心：必须开启 direct_upload: true %>
            <%= df.file_field :file, direct_upload: true, required: @need_file, id: "order_draft_file", class: "sr-only", data: { action: "change->common--order-edit-component#handleFileChange" } %>
            <p class="text-[9px] text-slate-400 mt-1 tracking-tighter" data-common--order-edit-component-target="uploadHint"><%= @upload_hint%></p>
          </div>
        </label>
      <% end %>
      <%# 底部状态条：初始宽度 0 %>
      <div class="absolute bottom-0 left-0 h-1 bg-[#0066b3] w-0 transition-all duration-300" data-common--order-edit-component-target="progressBar"></div>
    </div>

    <%# 第二区：选择区 (保持原样) %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <%# 1. 结算客户 %>
      <div class="space-y-1" data-controller="dropdown">
        <label class="text-[10px] font-black text-slate-400 tracking-wider ml-1">结算客户</label>
        <div class="relative">
          <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" 
                  class="<%= @customer_cls %> w-full flex items-center justify-between px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-bold hover:border-[#0066b3] transition-all shadow-sm cursor-pointer">
            <span data-common--order-edit-component-target="customerNameText" class="truncate">
              <%= @order.customer_name %>
            </span>
            <%= heroicon @customer_icon, variant: :mini, options: { class: "h-4 w-4 text-slate-300" } %>
          </button>
          <%= f.hidden_field :customer_id, data: { "common--order-edit-component-target" => "customerIdInput" } %>
          <div data-dropdown-target="menu" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-xl shadow-2xl py-1 max-h-48 overflow-y-auto">
            <% @customers.each do |c| %>
              <button type="button" data-action="click->common--order-edit-component#selectCustomer click->dropdown#toggle" data-id="<%= c.id %>" data-name="<%= c.name %>" 
                      class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-blue-50 cursor-pointer">
                <%= c.name %>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <%# 2. 服务项目 %>
      <div class="space-y-1" data-controller="dropdown">
        <label class="text-[10px] font-black text-slate-400 tracking-wider ml-1">服务项目</label>
        <div class="relative">
          <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" 
                  class="w-full flex items-center justify-between px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-bold hover:border-[#0066b3] transition-all shadow-sm cursor-pointer">
            <span data-common--order-edit-component-target="serviceTypeText">
              <%= @order.service_type %>
            </span>
            <%= heroicon "chevron-down", variant: :mini, options: { class: "h-4 w-4 text-slate-300" } %>
          </button>
          <input type="hidden" value="<%= @order.service_type %>" data-common--order-edit-component-target="serviceTypeInput">
          <div data-dropdown-target="menu" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-xl shadow-2xl py-1">
            <% Biz::Unit.pluck(:service_type).uniq.each do |type| %>
              <button type="button"
                      data-common--order-edit-component-target="serviceTypeOption"
                      data-action="click->common--order-edit-component#selectService click->dropdown#toggle" data-value="<%= type %>" 
                      class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-blue-50 cursor-pointer">
                <%= type %>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <%# 3. 规格/幅面 %>
      <div class="space-y-1" data-controller="dropdown">
        <label class="text-[10px] font-black text-slate-400 tracking-wider ml-1">规格/幅面</label>
        <div class="relative">
          <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" 
                  class="w-full flex items-center justify-between px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-bold hover:border-[#0066b3] transition-all shadow-sm cursor-pointer">
            <span data-common--order-edit-component-target="categoryText">
              <%= @order.category_name %>
            </span>
            <%= heroicon "chevron-down", variant: :mini, options: { class: "h-4 w-4 text-slate-300" } %>
          </button>
          <input type="hidden" value="<%= @order.unit&.category_id %>" data-common--order-edit-component-target="categoryIdInput">
          <div data-dropdown-target="menu" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-xl shadow-2xl py-1 max-h-48 overflow-y-auto">
            <% @categories.each do |cat| %>
              <button type="button" 
                      data-common--order-edit-component-target="categoryOption"
                      data-action="click->common--order-edit-component#selectCategory click->dropdown#toggle" data-id="<%= cat.id %>" data-name="<%= cat.name %>" 
                      class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-blue-50 cursor-pointer">
                <%= cat.name %>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# 第三区：详情数值卡片 (保持原样) %>
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-5 grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="space-y-1">
        <%= f.label :quantity, "数量", class: "text-[10px] font-black text-slate-400 ml-1" %>
        <%= f.number_field :quantity, step: 0.01, 
            data: { 
              "common--order-edit-component-target" => "quantity", 
              action: "input->common--order-edit-component#calculate" 
            }, 
            class: "block w-full px-4 py-2.5 bg-slate-50 border-none rounded-xl font-mono font-bold" %>
      </div>

      <div class="space-y-1">
        <%= f.label :unit_price, "单价", class: "text-[10px] font-black text-slate-400 ml-1" %>
        <%= f.number_field :unit_price, step: 0.01, 
            data: { 
              "common--order-edit-component-target" => "unitPrice", 
              action: "input->common--order-edit-component#handlePriceManualChange" 
            }, 
            class: "block w-full px-4 py-2.5 bg-slate-50 border-none rounded-xl font-mono font-bold text-orange-600" %>
      </div>

      <div class="space-y-1 relative" data-controller="dropdown">
        <label class="text-[10px] font-black text-slate-400 ml-1">付款方式</label>
        <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="w-full flex items-center justify-between px-4 py-2.5 bg-slate-50 rounded-xl text-xs font-bold text-slate-700 hover:bg-slate-100 cursor-pointer">
          <span data-common--order-edit-component-target="paymentMethodText"><%= @order.payment_method %></span>
          <%= heroicon "credit-card", variant: :mini, options: { class: "h-4 w-4 text-slate-400" } %>
        </button>
        <%= f.hidden_field :payment_method, data: { "common--order-edit-component-target" => "paymentMethodInput" } %>
        <div data-dropdown-target="menu" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-xl shadow-2xl py-1">
          <% ["微信", "支付宝", "现金", "对公", "记账"].each do |m| %>
            <button type="button" data-action="click->common--order-edit-component#selectPayment click->dropdown#toggle" data-value="<%= m %>" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-blue-50 cursor-pointer">
              <%= m %>
            </button>
          <% end %>
        </div>
      </div>

      <div class="space-y-1 relative" data-controller="dropdown">
        <label class="text-[10px] font-black text-slate-400 ml-1">运输方式</label>
        <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="w-full flex items-center justify-between px-4 py-2.5 bg-slate-50 rounded-xl text-xs font-bold text-slate-700 hover:bg-slate-100 cursor-pointer">
          <span data-common--order-edit-component-target="deliveryMethodText"><%= @order.delivery_method %></span>
          <%= heroicon "truck", variant: :mini, options: { class: "h-4 w-4 text-slate-400" } %>
        </button>
        <%= f.hidden_field :delivery_method, data: { "common--order-edit-component-target" => "deliveryMethodInput" } %>
        <div data-dropdown-target="menu" class="hidden absolute z-50 mt-1 w-full bg-white border border-slate-200 rounded-xl shadow-2xl py-1 transition transform">
          <% ["快递", "到付", "自取", "送货"].each do |m| %>
            <button type="button" data-action="click->common--order-edit-component#selectDelivery click->dropdown#toggle" data-value="<%= m %>" class="w-full text-left px-4 py-2 text-xs font-bold text-slate-600 hover:bg-blue-50 cursor-pointer">
              <%= m %>
            </button>
          <% end %>
        </div>
      </div>
      
      <div class="space-y-1">
        <%= f.label :delivery_fee, "运费/额外", class: "text-[10px] font-black text-slate-400 ml-1" %>
        <%= f.number_field :delivery_fee, step: 0.1, disabled: @order.delivery_method != "快递",
            data: { 
              "common--order-edit-component-target" => "deliveryFee", 
              "action" => "input->common--order-edit-component#calculate" 
            }, 
            class: "block w-full px-4 py-2.5 bg-slate-50 border-none rounded-xl font-mono text-sm" %>
      </div>

      <div class="space-y-1">
        <%= f.label :remark, "说明备注", class: "text-[10px] font-black text-slate-400 ml-1" %>
        <%= f.text_field :remark, placeholder: "备注...", class: "block w-full px-4 py-2.5 bg-slate-50 border-none rounded-xl text-xs" %>
      </div>
    </div>

    <%# 底部操作栏 %>
    <%= action%>
  <% end %>
</div>

