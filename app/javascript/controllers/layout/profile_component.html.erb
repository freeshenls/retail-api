<%# app/components/layout/profile_component.html.erb %>
<div class="max-w-3xl mx-auto py-12 px-4" data-controller="layout--profile-component">
  <%# 顶部标题与 Tab 切换 %>
  <div class="mb-8 flex flex-col gap-6 px-1">
    <div class="flex justify-between items-end">
      <h1 class="text-xl font-black text-slate-800 tracking-tight">个人中心</h1>
      <div class="px-2.5 py-0.5 border-2 border-[#0066b3] text-[#0066b3] text-[10px] font-black rounded uppercase tracking-wider">
        <%= @user.role.description %>
      </div>
    </div>

    <%# Tab 按钮组 %>
    <div class="flex gap-8 border-b-2 border-slate-100">
      <button type="button" data-layout--profile-component-target="tab" data-id="info" data-action="click->layout--profile-component#changeTab" class="pb-3 border-b-2 text-xs font-black uppercase tracking-[0.2em] transition-all cursor-pointer">
        个人资料
      </button>
      <button type="button" data-layout--profile-component-target="tab" data-id="password" data-action="click->layout--profile-component#changeTab" class="pb-3 border-b-2 border-transparent text-xs font-black uppercase tracking-[0.2em] transition-all cursor-pointer">
        安全设置
      </button>
    </div>
  </div>

  <%# 主容器 %>
  <div data-layout--profile-component-target="panel" data-id="info" class="bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm">
    <%= form_with model: @user, url: profile_path, method: :patch, class: "flex flex-col" do |f| %>
      
      <%# 顶部：头像与账号 %>
      <div class="p-8 flex items-center gap-6 border-b-2 border-slate-50">
        <div class="relative group w-16 h-16 shrink-0">
          <%# 注意这里的 target 命名：控制器名 + "-target" %>
          <div class="w-full h-full rounded-full border-2 border-slate-200 overflow-hidden bg-white" 
               data-layout--profile-component-target="preview">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-slate-200">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
              </div>
            <% end %>
          </div>
          <label class="absolute inset-0 flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 rounded-full cursor-pointer transition-all">
            <%= f.file_field :avatar, class: "hidden", data: { action: "change->layout--profile-component#previewImage" } %>
            <span class="text-white text-[9px] font-black">更换</span>
          </label>
        </div>
        <div>
          <h3 class="text-sm font-black text-slate-800 tracking-tight"><%= @user.email %></h3>
          <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-0.5">账号创建于 <%= joined_date %></p>
        </div>
      </div>

      <%# 表单资料 %>
      <div class="p-8 space-y-6">
        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest">昵称</label>
            <%= f.text_field :name, class: "w-full border-2 border-slate-100 rounded-lg text-[13px] font-bold text-slate-700 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
          </div>
          <div class="space-y-1.5">
            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest">联系电话</label>
            <%= f.text_field :phone, class: "w-full border-2 border-slate-100 rounded-lg text-[13px] font-bold text-slate-700 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest">个人简介</label>
          <%= f.text_area :bio, rows: 3, class: "w-full border-2 border-slate-100 rounded-lg text-[13px] text-slate-600 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
        </div>
      </div>

      <%# 关联客户 %>
      <div class="px-8 pb-8">
        <div class="p-5 border-2 border-slate-50 rounded-xl bg-slate-50/10">
          <label class="block text-[9px] font-black text-slate-300 uppercase tracking-[0.2em] mb-4">关联客户</label>
          <div class="flex flex-wrap gap-2.5">
            <% @customers.each do |customer| %>
              <div class="px-3 py-1 bg-white border-2 border-slate-50 rounded-lg flex items-center gap-2 shadow-sm">
                <div class="w-1.5 h-1.5 rounded-full bg-[#0066b3]"></div>
                <span class="text-[11px] font-black text-slate-600"><%= customer.name %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# 底部动作栏 (Flash 提示紧贴按钮左侧) %>
      <div class="px-8 py-5 border-t-2 border-slate-50 bg-white flex items-center justify-between gap-4">
        <div class="flex-1 flex justify-end">
          <% if helpers.notice.present? %>
            <div class="flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-lg">
              <div class="w-1 h-1 rounded-full bg-emerald-500"></div>
              <span class="text-[11px] font-black text-emerald-600 tracking-tight"><%= helpers.notice %></span>
            </div>
          <% end %>
          <% if helpers.alert.present? %>
            <div class="flex items-center gap-2 px-3 py-1.5 bg-rose-50 border border-rose-100 rounded-lg">
              <div class="w-1 h-1 rounded-full bg-rose-500"></div>
              <span class="text-[11px] font-black text-rose-600 tracking-tight"><%= helpers.alert %></span>
            </div>
          <% end %>
        </div>
        <div class="shrink-0">
          <%= f.submit "保存更改", class: "px-10 py-2.5 bg-[#0066b3] text-white text-[11px] font-black rounded-lg shadow-md hover:brightness-110 transition-all active:scale-95 cursor-pointer border-none" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# app/components/layout/profile_component.html.erb (安全设置面板 - 纵向三行版) %>
<div data-layout--profile-component-target="panel" data-id="password" class="hidden bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm">
  <%= form_with model: @user, url: profile_path, method: :patch, class: "flex flex-col" do |f| %>
    
    <%# 顶部：安全提示 (高度与个人资料头像区块对齐) %>
    <div class="p-8 border-b-2 border-slate-50 bg-rose-50/10">
      <div class="flex items-center gap-6">
        <div class="w-16 h-16 rounded-full bg-rose-50 flex items-center justify-center shrink-0 border-2 border-rose-100">
          <svg class="w-8 h-8 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-black text-slate-800 tracking-tight">安全与隐私</h3>
          <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-0.5">为了您的账号安全，修改密码需要验证当前原密码</p>
        </div>
      </div>
    </div>

    <%# 表单资料：各占一行布局 %>
    <div class="p-8 space-y-6">
      <%# 1. 原密码 %>
      <div class="max-w-md space-y-1.5">
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">当前原密码</label>
        <%= f.password_field :current_password, 
                             autocomplete: "current-password",
                             placeholder: "请输入旧密码",
                             class: "w-full border-2 border-slate-100 rounded-lg text-[13px] font-bold text-slate-700 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
      </div>

      <%# 2. 新密码 %>
      <div class="max-w-md space-y-1.5">
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">新密码</label>
        <%= f.password_field :password, 
                             autocomplete: "new-password",
                             placeholder: "不少于 6 位",
                             class: "w-full border-2 border-slate-100 rounded-lg text-[13px] font-bold text-slate-700 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
      </div>

      <%# 3. 确认新密码 %>
      <div class="max-w-md space-y-1.5">
        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">再次确认新密码</label>
        <%= f.password_field :password_confirmation, 
                             autocomplete: "new-password",
                             placeholder: "请再次输入",
                             class: "w-full border-2 border-slate-100 rounded-lg text-[13px] font-bold text-slate-700 focus:ring-0 focus:border-[#0066b3] transition-all px-3 py-2" %>
      </div>
      
      <div class="pt-2">
        <p class="text-[9px] text-slate-300 font-black uppercase tracking-wider leading-relaxed">
          温馨提示：修改密码后，您需要在所有已登录的设备上重新登录。
        </p>
      </div>
    </div>

    <%# 底部动作栏 (完全同步个人资料样式) %>
    <div class="px-8 py-5 border-t-2 border-slate-50 bg-white flex items-center justify-between gap-4">
      <div class="flex-1 flex justify-end">
        <% if helpers.notice.present? %>
          <div class="flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-lg">
            <div class="w-1 h-1 rounded-full bg-emerald-500"></div>
            <span class="text-[11px] font-black text-emerald-600 tracking-tight"><%= helpers.notice %></span>
          </div>
        <% end %>
        <% if helpers.alert.present? %>
          <div class="flex items-center gap-2 px-3 py-1.5 bg-rose-50 border border-rose-100 rounded-lg">
            <div class="w-1 h-1 rounded-full bg-rose-500"></div>
            <span class="text-[11px] font-black text-rose-600 tracking-tight"><%= helpers.alert %></span>
          </div>
        <% end %>
      </div>
      <div class="shrink-0">
        <%= f.submit "保存更改", class: "px-10 py-2.5 bg-[#0066b3] text-white text-[11px] font-black rounded-lg shadow-md hover:brightness-110 transition-all active:scale-95 cursor-pointer border-none" %>
      </div>
    </div>
  <% end %>
</div>

</div>
