<%# app/components/common/order_show_component.html.erb %>
<div class="max-w-5xl mx-auto py-8 px-4" data-controller="order--show-component">
  
  <%# 1. 顶部导航与状态 - no-print %>
  <div class="mb-6 flex justify-between items-center px-1 border-b border-slate-100 pb-5 no-print">
    <div class="flex items-center gap-3">
      <%= link_to request.referer, data: { turbo: false }, class: "p-2 bg-white border-2 border-slate-100 rounded-lg text-slate-400 hover:text-[#0066b3] hover:border-[#0066b3] transition-all shadow-sm" do %>
        <%= heroicon "chevron-left", variant: :mini, options: { class: "h-4 w-4", stroke_width: 2.5 } %>
      <% end %>
      <div>
        <h1 class="text-xl font-black text-slate-800 tracking-tight">订单详情</h1>
        <p class="text-[10px] text-slate-400 font-bold mt-0.5">订单编号: <%= @order.order_no %></p>
      </div>
    </div>
    
    <div class="flex flex-col items-end">
      <span class="text-[9px] font-black text-slate-400 tracking-widest mb-1 text-right">当前状态</span>
      <div class="px-4 py-1.5 bg-blue-50 border border-blue-100 text-[#0066b3] text-[11px] font-black rounded-lg tracking-wider">
        <%= "待提交" if @order.pending? %>
        <%= "等待抢单" if @order.submitted? && @order.staff.blank? %>
        <%= "等待发货" if @order.submitted? && @order.staff.present? %>
        <%= "已发货" if @order.approved? %>
        <%= "已退回" if @order.rejected? %>
        <%= "确认收货" if @order.received? %>
        <%= "财务已核实" if @order.checked? %>
      </div>
    </div>
  </div>

  <div class="hidden print:block border-b-4 border-slate-900 pb-6 mb-8">
    <div class="flex justify-between items-end">
      <div>
        <%= image_tag asset_path('logo.svg'), class: 'w-auto max-h-[36px] block', alt: '共点科技' %>
        <h1 class="text-3xl font-black tracking-tighter text-slate-900">生产任务指令单</h1>
        <p class="text-xs font-bold text-slate-500 mt-1">PRODUCTION TASK ORDER</p>
      </div>
      <div class="text-right">
        <p class="text-sm font-black font-mono text-slate-900">单号: <%= @order.order_no %></p>
        <p class="text-[10px] text-slate-400 font-bold tracking-tight">下单时间: <%= @order.created_at.strftime("%Y-%m-%d %H:%M") %></p>
        <p class="text-[10px] text-slate-400 font-bold tracking-tight">打印时间: <%= Time.current.strftime("%Y-%m-%d %H:%M") %></p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 print:block">
    <%# 左侧主内容区 %>
    <div class="lg:col-span-2 space-y-6 print:w-full">
      
      <%# 业务规格卡片 %>
      <div class="bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm print:shadow-none print:border-slate-900 print:rounded-none">
        <div class="p-6 border-b-2 border-slate-50 flex items-center justify-between print:bg-slate-50 print:border-slate-900">
          <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
            <div class="w-1.5 h-4 bg-[#0066b3] rounded-full print:bg-black print:border-l-[6px] print:border-[#0066b3]"></div>
            业务规格信息
          </h3>
          <div class="text-right no-print">
            <p class="text-[9px] font-black text-slate-400 tracking-widest uppercase mb-0.5">下单时间</p>
            <p class="text-[11px] font-bold font-mono text-slate-600"><%= @order.created_at.strftime("%Y-%m-%d %H:%M") %></p>
          </div>
        </div>
        
        <div class="p-8 grid grid-cols-1 md:grid-cols-4 gap-8 text-slate-700 print:grid-cols-4 print:gap-3 print:p-6">
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">服务类型</label>
            <p class="text-sm font-bold"><%= @order.service_type.presence %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">产品分类</label>
            <p class="text-sm font-bold"><%= @order.category_name.presence %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">生产数量</label>
            <p class="text-sm font-bold font-mono print:text-xl"><%= @order.quantity.to_i %> PCS</p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">业务单价</label>
            <p class="text-sm font-bold text-orange-600 font-mono print:text-slate-900">¥ <%= number_with_precision(@order.unit_price, precision: 2) %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">运输方式</label>
            <p class="text-sm font-bold font-mono print:text-slate-900"><%= @order.delivery_method %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">运费明细</label>
            <p class="text-sm font-bold font-mono print:text-slate-900">¥ <%= number_with_precision(@order.delivery_fee, precision: 2) %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">运单号</label>
            <p class="text-sm font-bold font-mono print:text-slate-900"><%= @order.tracking_number || "-" %></p>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">付款方式</label>
            <p class="text-sm font-bold font-mono print:text-slate-900"><%= @order.payment_method %></p>
          </div>
          <div class="space-y-1 md:col-span-4 print:col-span-4">
            <label class="text-[10px] font-black text-slate-400 tracking-widest print:text-slate-500">说明备注</label>
            <p class="text-sm font-bold font-mono print:text-slate-900"><%= @order.remark.presence || "暂无" %></p>
          </div>
        </div>
      </div>

      <%# 稿件资料卡片 %>
      <div class="bg-white border-2 border-slate-200 rounded-2xl overflow-hidden shadow-sm print:shadow-none print:border-slate-900 print:rounded-none">
        <div class="p-6 border-b-2 border-slate-50"><h3 class="text-sm font-black text-slate-800">关联稿件基础资料</h3></div>
        <div class="p-8">
          <div class="group flex items-center justify-between p-4 bg-slate-50 rounded-xl border-2 border-dashed border-slate-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[#0066b3] shadow-sm border border-slate-100">
                <%= heroicon "document-text", variant: :outline, options: { class: "h-5 w-5", stroke_width: 2 } %>
              </div>
              <div>
                <p class="text-sm font-black text-slate-700"><%= @order.draft_name %></p>
                <p class="text-[9px] text-slate-400 font-bold tracking-tight">设计稿件详情 / DESIGN DRAFT DETAILS</p>
              </div>
            </div>
            <% if @order.draft&.file&.attached? %>
              <%= link_to @order.draft.file.url(disposition: "attachment"), data: { turbo: false }, class: "no-print flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 text-[#0066b3] text-[10px] font-black rounded-lg hover:bg-[#0066b3] hover:text-white transition-all active:scale-95 shadow-sm" do %>
                <%= heroicon "arrow-down-tray", variant: :mini, options: { class: "w-3.5 h-3.5", stroke_width: 2.5 } %>
                下载稿件
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <%# --- 打印合并底栏 --- %>
      <div class="bottom-sign hidden print:grid grid-cols-4 divide-x-2 divide-slate-900 border-2 border-slate-900 mt-12 items-stretch">
        <div class="p-4 bg-slate-50/50">
          <label class="text-[9px] font-black text-slate-500 block mb-2">订单金额总计</label>
          <p class="text-xl font-black font-mono text-slate-900">¥ <%= number_with_precision(@order.amount, precision: 2) %></p>
          <p class="text-[8px] text-slate-400 mt-1 font-bold">客户: <%= @order.customer_name %></p>
        </div>
        <div class="p-4 min-h-[80px]">
          <p class="text-[9px] font-black text-slate-500 mb-2">下单负责人</p>
          <p class="text-sm font-black font-mono text-slate-900"><%= @order.draft&.user.name %></p>
        </div>
        <div class="p-4 min-h-[80px]">
          <p class="text-[9px] font-black text-slate-500 mb-2">生产负责人</p>
          <p class="text-sm font-black font-mono text-slate-900"><%= @order.staff&.name %></p>
        </div>
        <div class="p-4 min-h-[80px]">
          <p class="text-[9px] font-black text-slate-500 mb-2">成品签收</p>
          <p class="text-sm font-black font-mono text-slate-900"><%= @order.draft&.user.name %></p>
        </div>
      </div>
    </div>

    <%# 右侧侧边栏 %>
    <div class="space-y-6 no-print">
      <div class="bg-slate-900 rounded-2xl p-6 text-white shadow-lg">
        <label class="text-[9px] font-black text-slate-400 tracking-[0.2em] mb-4 block text-slate-400/80">订单金额总计</label>
        <div class="flex items-baseline gap-1 mb-6">
          <span class="text-xl font-light text-slate-400">¥</span>
          <span class="text-4xl font-black tracking-tighter"><%= number_with_precision(@order.amount, precision: 2) %></span>
        </div>
        <div class="space-y-3 pt-6 border-t border-white/10 text-[11px]">
          <div class="flex justify-between font-black"><span class="text-slate-400 font-bold">归属客户</span><span><%= @order.customer_name %></span></div>
          <div class="flex justify-between font-black"><span class="text-slate-400 font-bold">下单负责人</span><span class="text-amber-400"><%= @order.draft.user.name %></span></div>
          <div class="flex justify-between font-black"><span class="text-slate-400 font-bold">生产负责人</span><span class="text-blue-400"><%= @order.staff&.name || "等待抢单..." %></span></div>
        </div>
      </div>

      <%# 操作区 %>
      <div class="space-y-3 pt-2">
        <% if can_accpect?(user: helpers.current_user, order: @order) %>
          <%= button_to accept_staff_order_path(@order), method: :patch, data: { turbo: false },
              class: "w-full py-3 bg-[#0066b3] text-white text-xs font-black rounded-xl hover:bg-[#005596] shadow-md cursor-pointer transition-all active:scale-95 border-none" do %>
            立即接单抢单
          <% end %>
        <% end %>

        <% if can_approve?(user: helpers.current_user, order: @order) %>
        	<div class="space-y-4" >
            <% if @order.delivery_method == "快递" %>
              <%= render OrderAction::ApproveComponent.new(order: @order) %>
            <% else %>
              <%= button_to approve_staff_order_path(@order), method: :patch, data: { turbo: false },
                  class: "w-full flex items-center justify-center gap-2 px-12 py-3 bg-[#0066b3] text-white text-xs font-black rounded-xl hover:bg-[#005596] shadow-md cursor-pointer active:scale-95 transition-all border-none" do %>
                核实并发货
                <%= heroicon "paper-airplane", variant: :solid, options: { class: "h-3.5 w-3.5 text-white/90" } %>
              <% end %>
            <% end %>

            <div class="text-center mt-3 no-print flex items-center justify-center gap-1">
              <%= render OrderAction::RejectComponent.new(order: @order) %>
              <%# 分隔符 %>
              <span class="text-slate-200 text-[10px]">/</span>

              <%# 2. 手动调整 %>
              <%= link_to "手动调整", edit_staff_order_path(@order), 
                          class: "text-[11px] font-bold text-slate-400 hover:text-[#0066b3] transition-colors cursor-pointer underline underline-offset-4 decoration-slate-200 hover:decoration-[#0066b3]/30" %>
            </div>
          </div>
        <% end %>

        <% if can_receive?(user: helpers.current_user, order: @order) %>
        <%= render OrderAction::NormalComponent.new(
            url: finance_order_path(@order),
            params: { order: { status: :received } }, 
            title: "执行确认收货",
            sub_title:  "确定，已收货",
            hint: "请核实货物无误后执行，确认后将转交财务进行核实。",
            sub_hint: "确认收货？") %>
        <% end %>

        <% if can_check?(user: helpers.current_user, order: @order) %>
          <%= render OrderAction::NormalComponent.new(
              url: finance_order_path(@order),
              params: { order: { status: :checked } }, 
              title: "执行财务核实",
              sub_title:  "确定，已核实",
              hint: "请核实账目无误后执行，确认后将正式计入财务流水。",
              sub_hint: "确认核实？") %>
        <% end %>

        <% if can_settle?(user: helpers.current_user, order: @order) %>
          <%= render OrderAction::NormalComponent.new(
              url: finance_order_path(@order),
              params: { order: { is_settled: :true } }, 
              title: "执行结算入账",
              sub_title:  "确定，现在结算",
              hint: "请核实账目无误后执行，确认后将正式完成财务核算。",
              sub_hint: "确认结算？") %>
        <% end %>

      	<% if can_print_tag?(user: helpers.current_user, order: @order) %>
          <button data-order="<%= @order.order_no %>" 
                  data-draft="<%= @order.draft_name %>" 
                  data-quantity="<%= @order.quantity %>" 
                  data-action="order--show-component#printTag" 
                  class="w-full flex items-center justify-center gap-2 px-8 py-3 bg-white border border-slate-200 text-slate-600 text-xs font-black rounded-xl hover:bg-slate-50 cursor-pointer shadow-sm active:scale-95 transition-all">
            <%= heroicon "printer", variant: :outline, options: { class: "h-4 w-4" } %>
            打印标签
          </button>
        <% end %>
        <% if can_print_task?(user: helpers.current_user, order: @order) %>
          <button onclick="window.print()" class="w-full flex items-center justify-center gap-2 px-8 py-3 bg-white border border-slate-200 text-slate-600 text-xs font-black rounded-xl hover:bg-slate-50 cursor-pointer shadow-sm active:scale-95 transition-all">
            <%= heroicon "printer", variant: :outline, options: { class: "h-4 w-4" } %>
            打印生产任务单
          </button>
        <% end %>
      </div>

      <%# 流程进度 - 增加 Amber 状态显示逻辑 %>
      <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 shadow-sm no-print">
        <h4 class="text-[11px] font-black text-slate-800 tracking-widest mb-4 border-b border-slate-50 pb-2">流程进度</h4>
        <div class="space-y-5">          
          <%# 阶段1：已提交 %>
          <% if @order.staff.nil? %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "等待抢单...", show_time: false) %>
          <% else %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "员工已接单", show_time: @order.submitted?) %>
          <% end %>

          <%# 阶段2：已退回 %>
          <%= render OrderAmber::RejectComponent.new(order: @order) if @order.rejected? %>

          <%# 阶段3：已发货 %>
          <% if @order.approved? %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "已发货", show_time: true) %>
          <% end %>

          <%# 阶段4：确认收货 %>
          <% if @order.received? %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "已发货", show_time: false) %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "确认收货", show_time: true) %>
          <% end %>

          <%# 阶段5：财务已核实 %>
          <% if @order.checked? %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "已发货", show_time: false) %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "确认收货", show_time: false) %>
            <%= render OrderAmber::NormalComponent.new(order: @order, title: "财务已核实", show_time: !@order.is_settled?) %>
            <% if @order.is_settled? %>
              <%= render OrderAmber::NormalComponent.new(order: @order, title: "已结算", show_time: true) %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <style>
    @media print {
      body { background: white !important; font-family: "SimSun", "Songti SC", serif; }
      .no-print { display: none !important; }
      @page { size: A4; margin: 1.5cm; }
      #tabs, aside, nav, header, footer { display: none !important; }
      body, html { background: white !important; margin: 0 !important; padding: 0 !important; }
      .max-w-5xl { max-width: 100% !important; width: 100% !important; margin: 0 !important; padding: 0 !important; }
      .bottom-sign.print\:grid-cols-4 { display: grid !important; grid-template-columns: 1.5fr 1fr 1fr 1fr !important; }
      p, h1, h3, label, span { color: black !important; }
    }
  </style>
</div>
