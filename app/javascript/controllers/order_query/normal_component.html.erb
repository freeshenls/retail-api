<%# --- 1. 搜索与筛选卡片：紧凑型设计 --- %>
<div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200" data-controller="order-query--normal-component">
  <h3 class="text-xs font-bold text-slate-700 mb-5 flex items-center gap-2 tracking-wider">
    <span class="w-1 h-3.5 bg-[#0066b3] rounded-sm"></span>
    订单查询
  </h3>

  <%= form_with url: @url, method: :get, class: "flex flex-wrap items-end gap-4" do |f| %>
    <%# 查询框 %>
    <div class="w-80 group">
      <label class="block text-[10px] font-bold text-slate-400 tracking-tight mb-1.5 ml-1">
        查询订单号/稿件名
      </label>
      
      <div class="relative">
        <%= f.text_field :order_no_or_draft_name, placeholder: "请输入订单号/稿件名", value: params[:order_no_or_draft_name], class: "w-full flex items-center justify-between py-2 px-3 bg-slate-50 border border-slate-200 text-slate-700 text-xs rounded-md font-bold hover:border-[#0066b3] focus:ring-2 focus:ring-[#0066b3]/10 transition-all cursor-pointer shadow-sm" %>
      </div>
    </div>

    <%# 时间选择 %>
    <div class="flex items-end gap-2">
      <div class="w-36">
        <label class="block text-[10px] font-bold text-slate-400 tracking-tight mb-1.5 ml-1">开始日期</label>
        <%= f.date_field :start_date, value: params[:start_date], onkeydown: "return false;", class: "w-full py-2 px-3 bg-slate-50 border border-slate-200 text-xs rounded-md font-bold text-slate-700 cursor-pointer shadow-sm" %>
      </div>
      <div class="w-36">
        <label class="block text-[10px] font-bold text-slate-400 tracking-tight mb-1.5 ml-1">结束日期</label>
        <%= f.date_field :end_date, value: params[:end_date], onkeydown: "return false;", class: "w-full py-2 px-3 bg-slate-50 border border-slate-200 text-xs rounded-md font-bold text-slate-700 cursor-pointer shadow-sm" %>
      </div>
    </div>

    <%# 按钮组 %>
    <div class="flex items-center gap-3 ml-2">
      <%= f.submit "查询", class: "px-5 py-2 bg-[#0066b3] text-white text-xs font-bold rounded-md hover:bg-[#005596] active:scale-95 transition-all cursor-pointer shadow-sm tracking-widest" %>
      <%= link_to "重置", @url, class: "text-[10px] font-bold text-slate-400 hover:text-slate-600 px-1" %>

      <% if @can_export %>
      
        <div class="w-px h-4 bg-slate-200 mx-1"></div>
        
        <%= link_to @export_url, class: "text-[10px] font-bold text-slate-400 hover:text-[#0066b3] tracking-wider" do %>
          导出
        <% end %>
      
      <% end %>
    </div>
  <% end %>
</div>
