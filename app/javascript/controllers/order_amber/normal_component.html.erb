<div class="flex gap-3 items-center">
  <div class="w-5 h-5 rounded-full bg-[#0066b3] flex items-center justify-center shrink-0">
    <%= heroicon "check", variant: :outline, options: { class: "h-3 w-3 text-white", stroke_width: 3 } %>
  </div>
  <div class="flex items-center gap-2">
    <p class="text-[11px] font-black text-slate-700"><%= @title %></p>

    <%# --- 新增：物流单号展示与复制逻辑 --- %>
    <% if @title == "已发货" && @order.delivery_method == "快递" %>
      <div class="flex items-center gap-1.5 ml-1 px-2 py-0.5 bg-slate-50 border border-slate-200 rounded-md group hover:border-blue-400 transition-colors cursor-pointer"
           data-controller="clipboard"
           data-clipboard-success-content-value="已复制"
           data-clipboard-text-value="<%= @order.tracking_number %>"
           data-action="click->clipboard#copy">
        
        <%# 单号文本 %>
        <span data-clipboard-target="source" class="text-[10px] font-mono font-bold text-slate-500 group-hover:text-[#0066b3]">
          <%= @order.tracking_number %>
        </span>

        <%# 复制图标/成功反馈按钮 %>
        <button type="button" data-clipboard-target="button" class="text-[10px] text-[#0066b3] text-slate-500 flex items-center">
          <%= heroicon "document-duplicate", variant: :mini, options: { class: "h-3 w-3 text-slate-400 group-hover:text-[#0066b3]" } %>
        </button>
      </div>
    <% end %>
  </div>
  <% if @show_time %>
  	<p class="text-[10px] text-slate-400 font-mono font-bold mt-0.5"><%= @order.updated_at.strftime("%m/%d %H:%M") %></p>
  <% end %>
</div>