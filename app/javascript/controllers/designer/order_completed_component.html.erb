<%# app/components/designer/order_completed_component.html.erb %>
<div class="bg-slate-50/50 px-6 py-4 border-b border-slate-200 flex justify-between items-center">
   <span class="text-xs font-bold text-slate-500 tracking-wider">订单交易明细</span>
   <span class="text-[10px] font-bold text-slate-400">共计 <%= @orders.count %> 笔订单, 总金额 ¥<%= @orders.map{|item| item.amount}.sum %></span>
</div>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-slate-200">
    <thead class="bg-slate-50/50">
      <tr>
        <th scope="col" class="whitespace-nowrap px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">订单编号</th>
        <th scope="col" class="whitespace-nowrap px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">稿件详情</th>
        <th scope="col" class="whitespace-nowrap px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">状态</th>
        <th scope="col" class="whitespace-nowrap px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">下单时间</th>
        <th scope="col" class="whitespace-nowrap px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200 bg-white text-slate-700">
      <% @orders.each do |order| %>
        <tr class="hover:bg-slate-50/50 transition-colors group">
          <%# 1. 订单编号 %>
          <td class="whitespace-nowrap px-6 py-4 whitespace-nowrap text-sm font-medium">
            <div class="flex items-center">
              <div class="w-1 h-4 bg-[#0066b3] rounded-full mr-2 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <span class="text-slate-900 font-mono font-bold tracking-tight">
                <%= order.order_no %>
              </span>
            </div>
          </td>

          <%# 2. 稿件详情 %>
          <td class="whitespace-nowrap px-6 py-4 whitespace-nowrap">
            <% if order.draft %>
              <div class="text-sm font-semibold text-slate-700"><%= order.draft.name %></div>
              <div class="mt-1 flex items-center gap-2">
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-orange-50 text-orange-600 border border-orange-100 uppercase">
                  BY: <%= order.draft.user&.name %>
                </span>
                <% if order.draft.file.attached? %>
                  <%= link_to order.draft.file.url(disposition: "attachment"), 
                              data: { turbo: false },
                              class: "flex items-center text-[10px] font-bold text-emerald-600 hover:text-emerald-700 transition-colors" do %>
                    <%= heroicon "arrow-down-tray", variant: :mini, options: { class: "w-3.5 h-3.5", stroke_width: 2.5 } %>
                    附件下载
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </td>

          <%# 3. 状态：单行展示 %>
          <td class="whitespace-nowrap px-6 py-4 whitespace-nowrap">
            <div class="flex items-center gap-x-2">
              <%# 流程状态 %>
              <% if order.submitted? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-200">已提交</span>
              <% elsif order.approved? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">已发货</span>
              <% elsif order.received? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200">确认收货</span>
              <% end %>

              <%# 结算状态 (一行展示，加一个中间的分隔点或直接靠间距) %>
              <% if order.is_settled %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-slate-100 text-slate-500 border border-slate-200">已结算</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-orange-50 text-orange-600 border border-orange-200">未结算</span>
              <% end %>
            </div>
          </td>

          <%# 4. 下单时间 %>
          <td class="whitespace-nowrap px-6 py-4 whitespace-nowrap text-sm font-medium">
            <div class="flex items-center">
              <span class="font-bold text-[11px] text-slate-400 font-mono">
                <%= order.created_at.strftime("%Y-%m-%d %H:%M") %>
              </span>
            </div>
          </td>

          <%# 5. 操作 %>
          <td class="whitespace-nowrap px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "查看", designer_order_path(order, request.query_parameters), 
                        data: { turbo: false },
                        class: "text-[#0066b3] hover:text-[#005596] font-bold transition-colors" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @orders.empty? %>
  <div class="px-6 py-16 text-center text-slate-400 italic text-sm">
    当前暂无已提交或结算订单
  </div>
<% end %>
