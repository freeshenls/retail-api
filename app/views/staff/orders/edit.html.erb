<%# app/views/staff/orders/show.html.erb %>
<%= render layout: "staff/layout" do %>
  <%# 这里的代码会注入到 layout 的 yield 位置，也就是 main_content 内部 %>

  <%= render Order::EditComponent.new(
      user: current_user, 
      order: @order, 
      url: staff_order_path(@order)
    ) do |c| %>
      <% c.with_action do %>
        <%= render Staff::OrderEditComponent.new %>
      <% end %>
  <% end %>
<% end %>
